generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  password          String?
  image             String?
  role              UserRole           @default(USER)
  accounts          Account[]
  sessions          Session[]
  
  // Track registration progress
  registrationStatus RegistrationStatus @default(PENDING)
  
  // Link to full resident profile
  residentProfile   Resident?
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum UserRole {
  ADMIN
  USER
}

enum RegistrationStatus {
  PENDING
  EMAIL_VERIFIED
  IDENTITY_UPLOADED
  PROFILE_COMPLETED
  VERIFIED
  REJECTED
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dining {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  address       String
  cuisineType   String?
  openingHours  String?
  contactNumber String?
  facebookUrl   String?
  imageUrl      String?
  
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Accommodation {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  address       String
  type          String
  priceRange    String?
  amenities     String?  @db.Text
  contactNumber String?
  websiteUrl    String?
  imageUrl      String?

  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TourismSpot {
  id            String   @id @default(cuid())
  name          String
  category      String
  description   String?  @db.Text
  address       String
  entranceFee   String?
  bestTimeToVisit String?
  contactNumber String?
  imageUrl      String?

  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  category      String
  startDate     DateTime
  endDate       DateTime
  venueName     String
  address       String
  contactNumber String?
  imageUrl      String?
  reminders     String[] @default([])

  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  author      String?
  category    String   @default("Announcement")
  imageUrl    String?
  publishDate DateTime @default(now())
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  priority    String   @default("Normal")
  category    String   @default("General")
  isPinned    Boolean  @default(false)
  isActive    Boolean  @default(true)
  expiryDate  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id             String    @id @default(cuid())
  title          String
  department     String
  description    String    @db.Text
  qualifications String    @db.Text
  requirements   String    @db.Text
  salary         String?
  employmentType String
  deadline       DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Official {
  id            String    @id @default(cuid())
  name          String
  position      String
  contactNumber String?
  facebookUrl   String?
  bio           String?   @db.Text
  imageUrl      String?
  termStart     DateTime?
  termEnd       DateTime?
  order         Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Hotline {
  id           String    @id @default(cuid())
  name         String
  category     String
  mobileNumber String?
  telephone    String?
  address      String?
  order        Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  title        String
  description  String    @db.Text
  category     String
  status       String
  location     String
  budget       String?
  contractor   String?
  startDate    DateTime?
  endDate      DateTime?
  progress     Int       @default(0)
  imageUrl     String?
  isPublished  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Household {
  id             String    @id @default(cuid())
  headId         String?   @unique
  head           Resident? @relation("HouseholdHead", fields: [headId], references: [id])
  
  barangay       String
  latitude       Float?
  longitude      Float?
  householdSize  Int       @default(1)
  contactNumber  String?
  riskLevel      String    @default("Safe")
  notes          String?   @db.Text
  
  members        Resident[] @relation("HouseholdMembers")
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Resident {
  id                     String    @id @default(cuid())
  userId                 String?   @unique
  user                   User?     @relation(fields: [userId], references: [id])
  
  firstName              String
  lastName               String
  middleName             String?
  suffix                 String?
  gender                 String
  dateOfBirth            DateTime
  age                    Int?
  placeOfBirth           String?
  civilStatus            String
  citizenship            String    @default("Filipino")
  height                 String?
  weight                 String?
  religion               String?
  bloodType              String?

  houseNumber            String?
  street                 String?
  sitio                  String?
  purok                  String?
  barangay               String
  municipality           String    @default("Mapandan")
  province               String    @default("Pangasinan")
  contactNumber          String?
  email                  String?

  isHead                 Boolean   @default(false)
  relationshipToHead     String?
  
  householdId            String?
  household              Household? @relation("HouseholdMembers", fields: [householdId], references: [id])
  ownedHousehold         Household? @relation("HouseholdHead")

  tin                    String?
  gsis                   String?
  sss                    String?
  occupation             String?
  employer               String?

  motherFirstName        String?
  motherMiddleName       String?
  motherLastName         String?
  fatherFirstName        String?
  fatherMiddleName       String?
  fatherLastName         String?
  
  familyMembers          FamilyMember[]

  idType                 String?
  idFrontUrl             String?
  idBackUrl              String?
  livenessUrl            String?

  educationalAttainment  String?
  employmentStatus       String?
  monthlyIncome          String?

  isSenior               Boolean   @default(false)
  isPWD                  Boolean   @default(false)
  isSoloParent           Boolean   @default(false)
  isIndigenous           Boolean   @default(false)
  is4Ps                  Boolean   @default(false)
  otherSector            String?

  dataPrivacyConsent     Boolean   @default(false)
  consentTimestamp       DateTime?
  receivedBy             String?
  officialPosition       String?
  dateReceived           DateTime?

  imageUrl               String?
  registeredAt           DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model FamilyMember {
  id          String   @id @default(cuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  
  fullName    String
  relationship String
  age         Int?
  birthDate   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DisasterMap {
  id          String   @id @default(cuid())
  title       String
  location    String?
  description String?  @db.Text
  imagePath   String?
  riskLevel   String?
  isPublished Boolean  @default(true)
  
  zones       DisasterZone[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DisasterZone {
  id            String       @id @default(cuid())
  disasterMapId String?
  disasterMap   DisasterMap? @relation(fields: [disasterMapId], references: [id])
  
  type        String
  typeColor   String
  riskLevel   String
  riskColor   String
  
  shapes      Json     @default("[]")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?  @db.Text
  tagline     String?
  imageUrl    String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  primaryBtnText String?
  primaryBtnLink String?
  secondaryBtnText String?
  secondaryBtnLink String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
