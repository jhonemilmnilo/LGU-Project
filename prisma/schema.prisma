generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  ADMIN
  USER
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------
// LOCAL TOURISM MODULES
// ----------------------------------------

model Dining {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  address       String
  cuisineType   String?
  openingHours  String?
  contactNumber String?
  facebookUrl   String?
  imageUrl      String?
  
  // Location Tracking
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Accommodation {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  address       String
  type          String   // e.g. Resort, Hotel, Homestay
  priceRange    String?
  amenities     String?  @db.Text
  contactNumber String?
  websiteUrl    String?
  imageUrl      String?

  // Location Tracking
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TourismSpot {
  id            String   @id @default(cuid())
  name          String
  category      String   // e.g. Beach, Falls, Historical, Park
  description   String?  @db.Text
  address       String
  entranceFee   String?
  bestTimeToVisit String?
  contactNumber String?
  imageUrl      String?

  // Location Tracking
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  category      String   // e.g. Festival, Community, Holiday
  startDate     DateTime
  endDate       DateTime
  venueName     String
  address       String
  contactNumber String?
  imageUrl      String?
  reminders     String[] @default([])

  // Location Tracking
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?  @db.Text

  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  author      String?
  category    String   @default("Announcement")
  imageUrl    String?
  publishDate DateTime @default(now())
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  priority    String   @default("Normal") // Low, Normal, High, Critical
  category    String   @default("General") // Weather, Public Service, Health, Emergency
  isPinned    Boolean  @default(false)
  isActive    Boolean  @default(true)
  expiryDate  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id             String    @id @default(cuid())
  title          String
  department     String
  description    String    @db.Text
  qualifications String    @db.Text
  requirements   String    @db.Text
  salary         String?
  employmentType String
  deadline       DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Official {
  id            String    @id @default(cuid())
  name          String
  position      String
  contactNumber String?
  facebookUrl   String?
  bio           String?   @db.Text
  imageUrl      String?
  termStart     DateTime?
  termEnd       DateTime?
  order         Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Hotline {
  id           String    @id @default(cuid())
  name         String
  category     String
  mobileNumber String?
  telephone    String?
  address      String?
  order        Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id           String    @id @default(cuid())
  title        String
  description  String    @db.Text
  category     String
  status       String
  location     String
  budget       String?
  contractor   String?
  startDate    DateTime?
  endDate      DateTime?
  progress     Int       @default(0)
  imageUrl     String?
  isPublished  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Household {
  id             String    @id @default(cuid())
  headOfFamily   String
  barangay       String
  latitude       Float
  longitude      Float
  householdSize  Int
  contactNumber  String?
  riskLevel      String    @default("Safe")
  specialSectors String?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Resident {
  id                     String    @id @default(cuid())
  firstName              String
  lastName               String
  middleName             String?
  dateOfBirth            DateTime
  gender                 String
  civilStatus            String
  bloodType              String?
  contactNumber          String?
  email                  String?
  barangay               String
  address                String    @db.Text
  occupation             String?
  emergencyContactName   String?
  emergencyContactNumber String?
  imageUrl               String?
  registeredAt           DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model DisasterMap {
  id          String   @id @default(cuid())
  title       String
  location    String?
  description String?  @db.Text
  imagePath   String?
  riskLevel   String?
  isPublished Boolean  @default(true)
  
  zones       DisasterZone[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DisasterZone {
  id            String       @id @default(cuid())
  disasterMapId String?
  disasterMap   DisasterMap? @relation(fields: [disasterMapId], references: [id])
  
  type        String   // e.g. "Flood", "Landslide", "Storm Surge"
  typeColor   String   // The identifying color for the disaster type (Hex)
  riskLevel   String   // e.g. "Low", "Medium", "High"
  riskColor   String   // The severity color (Hex)
  
  // Multi-Polygon Geometry (Array of coordinate arrays)
  shapes      Json     @default("[]")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------------
// SYSTEM & WEBSITE CONFIGURATION
// ----------------------------------------

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "site_logo", "maintenance_mode", "site_name"
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?  @db.Text
  tagline     String?  // e.g. "The Home of the Umbrella Rocks"
  imageUrl    String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  primaryBtnText String?
  primaryBtnLink String?
  secondaryBtnText String?
  secondaryBtnLink String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
